# Multi-stage build for smaller final image
FROM python:3.12-slim AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Rust toolchain and maturin for building the Rust analyzer wheel
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:${PATH}"
RUN pip install --no-cache-dir maturin==1.9.6

# Copy requirements file
COPY src/encoder/requirements-*.txt /app/

ARG AMGIX_BUILD_FE=${AMGIX_BUILD_FE}
ENV AMGIX_BUILD_FE=${AMGIX_BUILD_FE}
ARG AMGIX_BUILD_ST=${AMGIX_BUILD_ST}
ENV AMGIX_BUILD_ST=${AMGIX_BUILD_ST}

# Install Python dependencies
RUN pip install --no-cache-dir --timeout=300 -r /app/requirements-common.txt
# RUN if [ "${AMGIX_BUILD_FE}" = "CPU" ]; then pip install --no-cache-dir --timeout=300 -r /app/requirements-fe-cpu.txt; fi
RUN if [ "${AMGIX_BUILD_ST}" = "CPU" ]; then pip install --no-cache-dir --timeout=300 -r /app/requirements-st-cpu.txt; fi
# RUN if [ "${AMGIX_BUILD_FE}" = "GPU" ]; then pip install --no-cache-dir --timeout=300 -r /app/requirements-fe-gpu.txt; fi
RUN if [ "${AMGIX_BUILD_ST}" = "GPU" ]; then pip install --no-cache-dir --timeout=300 -r /app/requirements-st-gpu.txt; fi

# Build and install amgix_analyzers (Rust PyO3 extension)
COPY libs/analyzers /app/libs/analyzers
RUN cd /app/libs/analyzers \
    && maturin build --release \
    && pip install --no-cache-dir target/wheels/*.whl

# Final stage - minimal runtime image
FROM python:3.12-slim

# Set working directory
WORKDIR /app

# Copy Python packages from builder stage
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application files
COPY src /app/src
COPY build/run-encoder.sh /app/run-encoder.sh
RUN chmod +x /app/run-encoder.sh

# Create a non-root user for security
RUN useradd -m -s /bin/bash appuser && \
    chown -R appuser:appuser /app
USER appuser

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

ARG AMGIX_VERSION=${AMGIX_VERSION}
ENV AMGIX_VERSION=${AMGIX_VERSION}
ARG AMGIX_BUILD_FE=${AMGIX_BUILD_FE}
ENV AMGIX_BUILD_FE=${AMGIX_BUILD_FE}
ARG AMGIX_BUILD_ST=${AMGIX_BUILD_ST}
ENV AMGIX_BUILD_ST=${AMGIX_BUILD_ST}

VOLUME ["/data"]

# Run the encoder service
ENTRYPOINT ["/app/run-encoder.sh"]


